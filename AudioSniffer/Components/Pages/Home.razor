@page "/"
@rendermode InteractiveServer
@using AudioSniffer.Services
@using System.IO
@using System.Linq
@inject IAudioAnalysisService AudioService
@inject IJSRuntime JSRuntime

<PageTitle>AudioSniffer - Анализ аудио</PageTitle>

<div class="audio-analyzer-container">
    <div class="neon-background">
        <div class="neon-grid"></div>
        <div class="neon-orb neon-orb-1"></div>
        <div class="neon-orb neon-orb-2"></div>
        <div class="neon-orb neon-orb-3"></div>
        <div class="neon-orb neon-orb-4"></div>
    </div>
    
    <div class="content-wrapper">
        <h1 class="neon-title">
            <span class="glitch">AudioSniffer</span>
        </h1>
        <p class="subtitle">Определяет, создано ли аудио с помощью ИИ</p>
        
        <div class="upload-section">
            <InputFile
                OnChange="HandleFileSelected"
                class="file-input"
                id="fileInput"
                accept="audio/*"
                disabled="@_isProcessing" />

            <label for="fileInput" class="neon-button @(_isProcessing ? "disabled" : "")">
                <span class="button-glow"></span>
                <span class="button-text">
                    @if (_isProcessing)
                    {
                        <span class="spinner"></span>
                        <text>Обработка...</text>
                    }
                    else
                    {
                        <text>Загрузить файл</text>
                    }
                </span>
            </label>
        </div>

        @if (_selectedFileName != null)
        {
            <div class="file-info neon-card fade-in">
                <span class="file-name">@_selectedFileName</span>
            </div>
        }

        @if (_waveformData != null && _waveformData.Length > 0)
        {
            <div class="waveform-container neon-card fade-in">
                <div class="canvas-container">
                    <canvas @ref="_canvasRef" id="waveformCanvas"></canvas>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(_analysisResult))
        {
            <div class="result-section fade-in">
                <div class="result-label neon-card">
                    <span class="label-glow">Результат:</span>
                </div>

                <div class="result-content neon-card">
                    <p class="result-text">@_analysisResult</p>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="error-message neon-card fade-in">
                <span class="error-icon"></span>
                <span>@_errorMessage</span>
            </div>
        }
    </div>
</div>

@code {
    private ElementReference _canvasRef;
    private string? _selectedFileName;
    private string? _analysisResult;
    private string? _errorMessage;
    private float[]? _waveformData;
    private bool _isProcessing;

    private async Task HandleFileSelected(InputFileChangeEventArgs eventArgs)
    {
        _errorMessage = null;
        _analysisResult = null;
        _waveformData = null;
        _selectedFileName = null;

        IBrowserFile file = eventArgs.File;

        if (file == null)
            return;

        if (file.Size > 50 * 1024 * 1024)
        {
            _errorMessage = "Файл слишком большой. Максимальный размер: 50 МБ";
            return;
        }

        if (file.Size == 0)
        {
            _errorMessage = "Файл пустой. Пожалуйста, выберите действительный аудиофайл.";
            return;
        }

        string fileExtension = Path.GetExtension(file.Name)?.ToLowerInvariant();
        string[] allowedExtensions = { ".mp3", ".wav", ".ogg", ".aac", ".flac", ".m4a", ".wma" };

        if (string.IsNullOrEmpty(fileExtension) || !allowedExtensions.Contains(fileExtension))
        {
            _errorMessage = "Неверный формат файла. Разрешены только аудиофайлы (MP3, WAV, OGG, AAC, FLAC, M4A, WMA).";
            return;
        }

        if (!IsValidAudioFileExtension(file.Name))
        {
            _errorMessage = "Неверное расширение файла. Пожалуйста, загрузите действительный аудиофайл.";
            return;
        }

        _isProcessing = true;
        _selectedFileName = SanitizeFileName(file.Name);
        StateHasChanged();

        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            byte[] audioData = memoryStream.ToArray();

            if (audioData.Length == 0)
            {
                _errorMessage = "Ошибка чтения файла. Файл может быть поврежден.";
                return;
            }

            _waveformData = await AudioService.GetWaveformDataAsync(audioData);
            StateHasChanged();

            if (_waveformData != null && _waveformData.Length > 0)
            {
                await DrawWaveformAsync();
            }

            _analysisResult = await AudioService.AnalyzeAudioAsync(audioData, _selectedFileName);
        }
        catch
        {
            _errorMessage = "Ошибка при обработке файла. Пожалуйста, попробуйте другой файл.";
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }

    private bool IsValidAudioFileExtension(string fileName)
    {
        string extension = Path.GetExtension(fileName)?.ToLowerInvariant();
        string[] validExtensions = { ".mp3", ".wav", ".ogg", ".aac", ".flac", ".m4a", ".wma" };
        return validExtensions.Contains(extension);
    }

    private string SanitizeFileName(string fileName)
    {
        char[] invalidChars = Path.GetInvalidFileNameChars();
        string sanitized = new string(fileName.Where(ch => !invalidChars.Contains(ch)).ToArray());
        return sanitized.Trim();
    }

    private async Task DrawWaveformAsync()
    {
        if (_waveformData == null || _waveformData.Length == 0)
            return;

        string json = System.Text.Json.JsonSerializer.Serialize(_waveformData);
        await JSRuntime.InvokeVoidAsync("drawWaveform", _canvasRef, json);
    }
}
