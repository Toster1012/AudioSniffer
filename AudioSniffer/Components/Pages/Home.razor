@page "/"
@rendermode RenderMode.InteractiveServer
@using AudioSniffer.Services
@using System.IO
@using System.Linq
@inject IAudioAnalysisService AudioService
@inject IRequestHistoryService HistoryService
@inject IJSRuntime JSRuntime

<PageTitle>AudioSniffer - Анализ аудио</PageTitle>

<div class="audio-analyzer-container">
    <div class="neon-background">
        <div class="neon-grid"></div>
        <div class="neon-orb neon-orb-1"></div>
        <div class="neon-orb neon-orb-2"></div>
        <div class="neon-orb neon-orb-3"></div>
        <div class="neon-orb neon-orb-4"></div>
    </div>
    
    <div class="content-wrapper">
        <h1 class="neon-title">
            <span class="glitch">AudioSniffer</span>
        </h1>
        <p class="subtitle">Определяет, создано ли аудио с помощью ИИ</p>
        
        <div class="upload-section">
            <InputFile
                OnChange="HandleFileSelectedAsync"
                class="file-input"
                id="fileInput"
                accept=".mp3,.wav,.ogg,.aac,.flac,.m4a"
                disabled="@_isProcessingFile" />

            <label for="fileInput" class="neon-button @(_isProcessingFile ? "disabled" : "")">
                <span class="button-glow"></span>
                <span class="button-text">
                    @if (_isProcessingFile)
                    {
                        <span class="spinner"></span>
                        <text>Обработка...</text>
                    }
                    else
                    {
                        <text>Загрузить файл</text>
                    }
                </span>
            </label>
        </div>

        @if (_selectedFileName != null)
        {
            <div class="file-info neon-card fade-in">
                <span class="file-name">@_selectedFileName</span>
            </div>
        }

        @if (_waveformDataArray != null && _waveformDataArray.Length > 0)
        {
            <div class="waveform-container neon-card fade-in">
                <div class="canvas-container">
                    <canvas @ref="_waveformCanvasReference" id="waveformCanvas"></canvas>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(_analysisResultText))
        {
            <div class="result-section fade-in">
                <div class="result-label neon-card">
                    <span class="label-glow">Результат:</span>
                </div>

                <div class="result-content neon-card">
                    <p class="result-text">@_analysisResultText</p>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(_errorMessageText))
        {
            <div class="error-message neon-card fade-in">
                <span class="error-icon"></span>
                <span>@_errorMessageText</span>
            </div>
        }
    </div>
</div>

@code {
    private static readonly string[] AllowedExtensions = { ".mp3", ".wav", ".ogg", ".aac", ".flac", ".m4a" };

    private ElementReference _waveformCanvasReference;
    private string? _selectedFileName;
    private string? _analysisResultText;
    private string? _errorMessageText;
    private float[]? _waveformDataArray;
    private bool _isProcessingFile;

    private async Task HandleFileSelectedAsync(InputFileChangeEventArgs file_change_event)
    {
        _errorMessageText = null;
        _analysisResultText = null;
        _waveformDataArray = null;
        _selectedFileName = null;

        IBrowserFile selected_file = file_change_event.File;

        if (selected_file == null)
            return;

        if (selected_file.Size > 50 * 1024 * 1024)
        {
            _errorMessageText = "Файл слишком большой. Максимальный размер: 50 МБ";
            return;
        }

        if (selected_file.Size == 0)
        {
            _errorMessageText = "Файл пустой. Пожалуйста, выберите действительный аудиофайл.";
            return;
        }

        string file_extension = Path.GetExtension(selected_file.Name)?.ToLowerInvariant() ?? string.Empty;

        if (string.IsNullOrEmpty(file_extension) || !AllowedExtensions.Contains(file_extension))
        {
            _errorMessageText = $"Неверный формат файла. Разрешены: {string.Join(", ", AllowedExtensions).ToUpper()}";
            return;
        }

        _isProcessingFile = true;
        _selectedFileName = SanitizeFileName(selected_file.Name);
        StateHasChanged();

        try
        {
            await using Stream file_stream = selected_file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
            using MemoryStream memory_stream = new MemoryStream();
            await file_stream.CopyToAsync(memory_stream);
            byte[] audio_file_data = memory_stream.ToArray();

            if (audio_file_data.Length == 0)
            {
                _errorMessageText = "Ошибка чтения файла. Файл может быть поврежден.";
                return;
            }

            _waveformDataArray = await AudioService.GetWaveformDataAsync(audio_file_data);
            StateHasChanged();

            if (_waveformDataArray != null && _waveformDataArray.Length > 0)
            {
                await DrawWaveformAsync();
            }

            var (result_text, analysis_result) = await AudioService.AnalyzeAudioAsync(audio_file_data, _selectedFileName);
            _analysisResultText = result_text;

            if (analysis_result != null)
            {
                await HistoryService.SaveAnalysisAsync(analysis_result);
            }
        }
        catch
        {
            _errorMessageText = "Ошибка при обработке файла. Пожалуйста, попробуйте другой файл.";
        }
        finally
        {
            _isProcessingFile = false;
            StateHasChanged();
        }
    }

    private string SanitizeFileName(string original_file_name)
    {
        char[] invalid_file_name_characters = Path.GetInvalidFileNameChars();
        string sanitized_file_name = new string(original_file_name.Where(character => !invalid_file_name_characters.Contains(character)).ToArray());
        return sanitized_file_name.Trim();
    }

    private async Task DrawWaveformAsync()
    {
        if (_waveformDataArray == null || _waveformDataArray.Length == 0)
            return;

        string waveform_json = System.Text.Json.JsonSerializer.Serialize(_waveformDataArray);
        await JSRuntime.InvokeVoidAsync("drawWaveform", _waveformCanvasReference, waveform_json);
    }
}
