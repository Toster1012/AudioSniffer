@page "/admin"
@rendermode RenderMode.InteractiveServer
@using AudioSniffer.Models
@using AudioSniffer.Services
@inject IRequestHistoryService HistoryService

<PageTitle>Админ — История анализов</PageTitle>

<div class="admin-container">
    <div class="neon-background">
        <div class="neon-grid"></div>
        <div class="neon-orb neon-orb-1"></div>
        <div class="neon-orb neon-orb-2"></div>
    </div>

    <div class="admin-content">
        <div class="admin-header">
            <h1 class="admin-title">История анализов</h1>
            <p class="admin-subtitle">
                @if (!isLoading && histories != null)
                {
                    <span>@histories.Count @GetRecordsLabel(histories.Count)</span>
                }
            </p>
        </div>

        @if (isLoading)
        {
            <div class="admin-loading">
                <div class="loading-spinner"></div>
                <p>Загрузка данных...</p>
            </div>
        }
        else if (errorMessage != null)
        {
            <div class="admin-error neon-card">
                <span class="admin-error-icon">⚠</span>
                <span>@errorMessage</span>
            </div>
        }
        else if (histories == null || histories.Count == 0)
        {
            <div class="admin-empty neon-card">
                <div class="admin-empty-icon"> </div>
                <p class="admin-empty-title">Записей пока нет</p>
                <p class="admin-empty-sub">Загрузите аудиофайл для анализа</p>
            </div>
        }
        else
        {
            <div class="admin-stats">
                <div class="stat-card neon-card">
                    <div class="stat-value">@histories.Count</div>
                    <div class="stat-label">Всего анализов</div>
                </div>
                <div class="stat-card neon-card">
                    <div class="stat-value ai-value">@histories.Count(h => h.IsNeuralNetwork)</div>
                    <div class="stat-label">Обнаружено ИИ</div>
                </div>
                <div class="stat-card neon-card">
                    <div class="stat-value clean-value">@histories.Count(h => !h.IsNeuralNetwork)</div>
                    <div class="stat-label">Реальных аудио</div>
                </div>
                <div class="stat-card neon-card">
                    <div class="stat-value">@((histories.Average(h => h.OverallConfidence) * 100).ToString("F0"))%</div>
                    <div class="stat-label">Средняя уверенность</div>
                </div>
            </div>

            <div class="admin-table-wrap neon-card">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Файл</th>
                            <th>Уверенность</th>
                            <th>Результат</th>
                            <th>Длительность</th>
                            <th>Формат</th>
                            <th>Дата</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var h in histories)
                        {
                            <tr class="@(h.IsNeuralNetwork ? "row-ai" : "row-clean")">
                                <td class="cell-filename">
                                    <span class="file-icon-small"> </span>
                                    <span class="filename-text">@TruncateFileName(h.AudioFileId)</span>
                                </td>
                                <td>
                                    <div class="confidence-bar-wrap">
                                        <div class="confidence-bar">
                                            <div class="confidence-fill @(h.IsNeuralNetwork ? "fill-ai" : "fill-clean")"
                                                 style="width: @((h.OverallConfidence * 100).ToString("F0"))%"></div>
                                        </div>
                                        <span class="confidence-text">@h.OverallConfidence.ToString("P0")</span>
                                    </div>
                                </td>
                                <td>
                                    @if (h.IsNeuralNetwork)
                                    {
                                        <span class="result-badge badge-ai">ИИ</span>
                                    }
                                    else
                                    {
                                        <span class="result-badge badge-clean">Реальное</span>
                                    }
                                </td>
                                <td class="cell-secondary">@h.DurationSeconds.ToString("F1") с</td>
                                <td class="cell-secondary">@(string.IsNullOrEmpty(h.Format) ? "—" : h.Format.ToUpper())</td>
                                <td class="cell-secondary cell-date">@h.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<style>
    .admin-container {
        min-height: 100vh;
        position: relative;
        overflow: hidden;
        background: var(--background);
    }

    .admin-content {
        position: relative;
        z-index: 1;
        max-width: 1100px;
        margin: 0 auto;
        padding: 64px 24px 80px;
    }

    .admin-header {
        text-align: center;
        margin-bottom: 48px;
        animation: fadeInUp 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .admin-title {
        font-size: 52px;
        font-weight: 700;
        letter-spacing: -0.015em;
        color: var(--text-primary);
        line-height: 1.08;
        margin-bottom: 8px;
    }

    .admin-subtitle {
        font-size: 19px;
        color: var(--text-secondary);
        font-weight: 400;
    }

    .admin-loading {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 20px;
        padding: 80px 0;
        color: var(--text-secondary);
        font-size: 17px;
        animation: fadeInUp 0.5s ease;
    }

    .loading-spinner {
        width: 40px;
        height: 40px;
        border: 3px solid var(--border);
        border-top-color: var(--primary-blue);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    .admin-error {
        display: flex;
        align-items: center;
        gap: 12px;
        color: #ff453a;
        font-size: 17px;
        padding: 24px 28px;
        border-color: rgba(255, 69, 58, 0.3);
        animation: fadeInUp 0.5s ease;
    }

    .admin-error-icon {
        font-size: 22px;
    }

    .admin-empty {
        text-align: center;
        padding: 80px 40px;
        animation: fadeInUp 0.5s ease;
    }

    .admin-empty-icon {
        font-size: 56px;
        margin-bottom: 20px;
        opacity: 0.5;
    }

    .admin-empty-title {
        font-size: 22px;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 8px;
    }

    .admin-empty-sub {
        font-size: 15px;
        color: var(--text-secondary);
    }

    .admin-stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin-bottom: 24px;
        animation: fadeInUp 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.05s backwards;
    }

    .stat-card {
        text-align: center;
        padding: 28px 20px;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .stat-card:hover {
        transform: translateY(-2px);
    }

    .stat-value {
        font-size: 36px;
        font-weight: 700;
        letter-spacing: -0.02em;
        color: var(--text-primary);
        margin-bottom: 6px;
    }

    .ai-value {
        color: #ff453a;
    }

    .clean-value {
        color: #30d158;
    }

    .stat-label {
        font-size: 13px;
        color: var(--text-secondary);
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .admin-table-wrap {
        padding: 0;
        overflow: hidden;
        animation: fadeInUp 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.1s backwards;
    }

    .admin-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 15px;
    }

    .admin-table thead tr {
        border-bottom: 1px solid var(--border);
    }

    .admin-table th {
        padding: 16px 20px;
        text-align: left;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        color: var(--text-secondary);
    }

    .admin-table tbody tr {
        border-bottom: 1px solid var(--border);
        transition: background 0.15s ease;
    }

    .admin-table tbody tr:last-child {
        border-bottom: none;
    }

    .admin-table tbody tr:hover {
        background: rgba(0, 113, 227, 0.04);
    }

    .admin-table td {
        padding: 16px 20px;
        color: var(--text-primary);
        vertical-align: middle;
    }

    .cell-filename {
        display: flex;
        align-items: center;
        gap: 10px;
        max-width: 220px;
    }

    .file-icon-small {
        font-size: 16px;
        opacity: 0.7;
        flex-shrink: 0;
    }

    .filename-text {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        font-weight: 500;
    }

    .confidence-bar-wrap {
        display: flex;
        align-items: center;
        gap: 10px;
        min-width: 140px;
    }

    .confidence-bar {
        flex: 1;
        height: 6px;
        background: var(--border);
        border-radius: 3px;
        overflow: hidden;
    }

    .confidence-fill {
        height: 100%;
        border-radius: 3px;
        transition: width 0.5s ease;
    }

    .fill-ai {
        background: linear-gradient(90deg, #ff6b6b, #ff453a);
    }

    .fill-clean {
        background: linear-gradient(90deg, #34d26a, #30d158);
    }

    .confidence-text {
        font-size: 13px;
        font-weight: 600;
        color: var(--text-secondary);
        min-width: 36px;
        text-align: right;
    }

    .result-badge {
        display: inline-flex;
        align-items: center;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.02em;
    }

    .badge-ai {
        background: rgba(255, 69, 58, 0.12);
        color: #ff453a;
    }

    .badge-clean {
        background: rgba(48, 209, 88, 0.12);
        color: #30d158;
    }

    .cell-secondary {
        color: var(--text-secondary);
        font-size: 14px;
    }

    .cell-date {
        white-space: nowrap;
    }

    @@media (max-width: 900px) {
        .admin-stats {
            grid-template-columns: repeat(2, 1fr);
        }

        .admin-title {
            font-size: 36px;
        }
    }

    @@media (max-width: 600px) {
        .admin-content {
            padding: 40px 16px 60px;
        }

        .admin-stats {
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
        }

        .stat-value {
            font-size: 28px;
        }

        .admin-table th:nth-child(4),
        .admin-table th:nth-child(5),
        .admin-table td:nth-child(4),
        .admin-table td:nth-child(5) {
            display: none;
        }
    }
</style>

@code {
    private List<RequestHistory>? histories;
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            histories = await HistoryService.GetAllAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Не удалось загрузить историю: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private string TruncateFileName(string name)
    {
        if (string.IsNullOrEmpty(name)) return "—";
        return name.Length > 28 ? name[..25] + "..." : name;
    }

    private string GetRecordsLabel(int count)
    {
        if (count % 100 is >= 11 and <= 14) return "записей";
        return (count % 10) switch
        {
            1 => "запись",
            2 or 3 or 4 => "записи",
            _ => "записей"
        };
    }
}
