@page "/admin"
@using AudioSniffer.Models
@using AudioSniffer.Services
@inject IRequestHistoryService HistoryService

<PageTitle>Админ — История</PageTitle>

<h3>История анализов</h3>

@if (isLoading)
{
    <p>Загрузка...</p>
}
else if (errorMessage != null)
{
    <div class="alert alert-danger">
        @errorMessage
    </div>
}
else if (histories == null || histories.Count == 0)
{
    <p>Записей пока нет</p>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>ID файла</th>
                <th>Уверенность</th>
                <th>Генерация ИИ</th>
                <th>Длительность</th>
                <th>Дата</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var h in histories)
            {
                <tr>
                    <td>@h.AudioFileId</td>
                    <td>@h.OverallConfidence.ToString("P0")</td>
                    <td>
                        @if (h.IsNeuralNetwork)
                        {
                            <span class="badge bg-danger">Да</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Нет</span>
                        }
                    </td>
                    <td>@h.DurationSeconds.ToString("F1") с</td>
                    <td>@h.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<RequestHistory>? histories;
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            histories = await HistoryService.GetAllAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Не удалось загрузить историю: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}